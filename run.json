{
    "apps": [{
        "name": "bot-telegram",
        "script": "artisan",
        "args": ["serve", "--host=0.0.0.0", "--port=3000"],
        "instances": 1,
        "autorestart": true,
        "max_restarts": 10,
        "min_uptime": "10s",
        "max_memory_restart": "500M",
        "interpreter": "php",
        "watch": false,
        "ignore_watch": [
            "node_modules",
            "storage/logs",
            "storage/framework",
            "bootstrap/cache",
            "log",
            "*.log"
        ],
        "error_file": "./log/err.log",
        "out_file": "./log/out.log",
        "log_file": "./log/combined.log",
        "time": true,
        "env": {
            "NODE_ENV": "development"
        }
    }]
}
